# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; never commit real credentials.
#
# Both variables below are safe to expose in the browser bundle —
# they are the public-facing Supabase anon key, not the service role key.
# Access control is enforced by Row Level Security (RLS) on the database side.
#
# UNSAFE — do NOT add these to this file or any frontend env file:
#   SUPABASE_SERVICE_ROLE_KEY  (bypasses RLS — server-side only)
#   Any private API keys, admin secrets, or deployment tokens

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
